<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD">

    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="-70dp"
        android:alpha="0.55"
        android:background="@drawable/bg_lamba_glow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="260dp"
        android:alpha="0.35"
        android:background="@drawable/bg_lamba_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="20dp"
        android:paddingEnd="32dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Меню"
                android:padding="9dp"
                android:src="@drawable/ic_lamba_menu"
                app:tint="#960018" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp">

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="center"
                    android:contentDescription="Уведомления"
                    android:src="@drawable/ic_lamba_notifications"
                    app:tint="#101114" />

                <View
                    android:id="@+id/notificationDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/bg_lamba_notification_dot"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <Space
            android:layout_width="1dp"
            android:layout_height="16dp" />

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Привет! Я твоя машина."
            android:textColor="#101114"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="Всегда на связи. Чем могу помочь?"
            android:textColor="#77777E"
            android:textSize="19sp" />

        <FrameLayout
            android:id="@+id/cardCar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5"
            android:layout_marginTop="12dp"
            android:foreground="?attr/selectableItemBackground">

            <View
                android:layout_width="260dp"
                android:layout_height="190dp"
                android:layout_gravity="center"
                android:alpha="0.55"
                android:background="@drawable/bg_lamba_car_glow" />

            <ImageView
                android:id="@+id/ivLambaCar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="Автомобиль"
                android:scaleType="fitCenter"
                android:src="@drawable/lamba_car_cropped" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="4dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCarName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Автомобиль"
                    android:textColor="#101114"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCarInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#77777E"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnTalkToCar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iconTalkToCar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_lamba_timeline"
                    app:tint="#960018"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="16dp"
                    android:text="Проверить состояние"
                    android:textColor="#101114"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconTalkToCar"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnExpenses"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iconExpenses"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_lamba_wallet"
                    app:tint="#960018"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="16dp"
                    android:text="Последние расходы"
                    android:textColor="#101114"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconExpenses"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnService"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iconService"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_lamba_build"
                    app:tint="#960018"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="16dp"
                    android:text="Последнее ТО"
                    android:textColor="#101114"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconService"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnAddRecord"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iconAddRecord"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_lamba_add_box"
                    app:tint="#960018"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="16dp"
                    android:text="Добавить запись"
                    android:textColor="#101114"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconAddRecord"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/homeMessageBar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="14dp">

            <FrameLayout
                android:id="@+id/homeInputFrame"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_lamba_chat_input"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHomeSend"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <EditText
                    android:id="@+id/etHomeMessage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Расскажи машине, что произошло..."
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="3"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="#101114"
                    android:textColorHint="#9B9BA3"
                    android:textSize="17sp" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnHomeSend"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_lamba_send_button"
                android:contentDescription="Отправить"
                android:padding="13dp"
                android:src="@drawable/ic_lamba_send_pedal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FFFFFF" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/drawerOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/drawerScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#6B000000"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/drawerPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@drawable/bg_lamba_drawer_panel"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="26dp"
            android:paddingEnd="28dp"
            android:paddingBottom="26dp"
            android:maxWidth="320dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans"
                    android:includeFontPadding="false"
                    android:text="LAMBA"
                    android:textColor="#960018"
                    android:textSize="33sp"
                    android:textStyle="bold|italic" />

                <ImageButton
                    android:id="@+id/btnDrawerClose"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Закрыть"
                    android:padding="11dp"
                    android:src="@drawable/ic_lamba_close"
                    app:tint="#101114" />
            </LinearLayout>

            <Space
                android:layout_width="1dp"
                android:layout_height="28dp" />

            <LinearLayout
                android:id="@+id/menuHistory"
                style="@style/LambaDrawerEntry">

                <ImageView
                    style="@style/LambaDrawerIcon"
                    android:src="@drawable/ic_lamba_history"
                    app:tint="#960018" />

                <TextView
                    style="@style/LambaDrawerText"
                    android:text="История" />

                <ImageView
                    style="@style/LambaDrawerArrow"
                    android:rotation="180"
                    android:src="@drawable/ic_lamba_arrow_back"
                    app:tint="#77777E" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuStats"
                style="@style/LambaDrawerEntry">

                <ImageView
                    style="@style/LambaDrawerIcon"
                    android:src="@drawable/ic_lamba_stats"
                    app:tint="#960018" />

                <TextView
                    style="@style/LambaDrawerText"
                    android:text="Статистика" />

                <ImageView
                    style="@style/LambaDrawerArrow"
                    android:rotation="180"
                    android:src="@drawable/ic_lamba_arrow_back"
                    app:tint="#77777E" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="18dp"
                android:background="#E7E7EA" />

            <LinearLayout
                android:id="@+id/menuRequestsHeader"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="История запросов"
                    android:textColor="#101114"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_lamba_chevron_down"
                    app:tint="#101114" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                    android:id="@+id/menuProfile"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_lamba_bot_bubble"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_red_light"
                        android:padding="13dp"
                        android:src="@drawable/ic_lamba_person"
                        app:tint="#960018" />

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text=""
                        android:textColor="#101114"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:rotation="180"
                        android:src="@drawable/ic_lamba_arrow_back"
                        app:tint="#77777E" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

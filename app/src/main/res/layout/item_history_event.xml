<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/timelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:layout_marginStart="13dp"
        android:background="@drawable/bg_history_timeline_line"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/timelineDot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:background="@drawable/bg_history_timeline_dot"
        android:elevation="3dp"
        app:layout_constraintBottom_toBottomOf="@id/cardHistoryEvent"
        app:layout_constraintEnd_toEndOf="@id/timelineLine"
        app:layout_constraintStart_toStartOf="@id/timelineLine"
        app:layout_constraintTop_toTopOf="@id/cardHistoryEvent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardHistoryEvent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_history_card"
        android:elevation="4dp"
        android:minHeight="96dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivEventIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_history_icon"
            android:contentDescription="@null"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#D32F2F" />

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#000000"
            android:textSize="19sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tvEventDetails"
            app:layout_constraintEnd_toStartOf="@id/tvEventAmount"
            app:layout_constraintStart_toEndOf="@id/ivEventIcon"
            app:layout_constraintTop_toTopOf="@id/ivEventIcon"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvEventDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#7D7D7D"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/ivEventIcon"
            app:layout_constraintEnd_toStartOf="@id/tvEventAmount"
            app:layout_constraintStart_toStartOf="@id/tvEventTitle"
            app:layout_constraintTop_toBottomOf="@id/tvEventTitle" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="#7D7D7D"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@id/tvEventAmount"
            app:layout_constraintStart_toStartOf="@id/tvEventTitle"
            app:layout_constraintTop_toBottomOf="@id/tvEventDetails" />

        <TextView
            android:id="@+id/tvEventAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#D32F2F"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

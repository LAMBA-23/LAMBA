<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="34dp"
        android:paddingTop="18dp"
        android:paddingEnd="34dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/btnProfileBack"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="Назад"
            android:padding="10dp"
            android:src="@drawable/ic_lamba_arrow_back"
            android:tint="#101114" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Профиль"
            android:textColor="#101114"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            style="@style/LambaFormLabel"
            android:layout_marginTop="28dp"
            android:text="Аккаунт" />

        <EditText
            android:id="@+id/etProfileUsername"
            style="@style/LambaFormInput"
            android:enabled="false"
            android:inputType="text"
            android:textColor="#77777E" />

        <TextView
            style="@style/LambaFormLabel"
            android:layout_marginTop="30dp"
            android:text="Автомобиль" />

        <EditText
            android:id="@+id/etProfileBrand"
            style="@style/LambaFormInput"
            android:hint="Марка"
            android:inputType="text"
            android:maxLength="64" />

        <EditText
            android:id="@+id/etProfileModel"
            style="@style/LambaFormInput"
            android:layout_marginTop="14dp"
            android:hint="Модель"
            android:inputType="text"
            android:maxLength="64" />

        <EditText
            android:id="@+id/etProfileYear"
            style="@style/LambaFormInput"
            android:layout_marginTop="14dp"
            android:hint="Год выпуска"
            android:inputType="number"
            android:maxLength="4" />

        <EditText
            android:id="@+id/etProfileMileage"
            style="@style/LambaFormInput"
            android:layout_marginTop="14dp"
            android:hint="Текущий пробег (км)"
            android:inputType="number"
            android:maxLength="10" />

        <TextView
            android:id="@+id/tvMileageLocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Пробег нельзя изменить после добавления записи в историю."
            android:textColor="#77777E"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVehicleError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#960018"
            android:textSize="16sp"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveProfileVehicle"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_lamba_send_button"
            android:text="Сохранить автомобиль"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            style="@style/LambaFormLabel"
            android:layout_marginTop="34dp"
            android:text="Смена пароля" />

        <EditText
            android:id="@+id/etCurrentPassword"
            style="@style/LambaFormInput"
            android:hint="Текущий пароль"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etNewPassword"
            style="@style/LambaFormInput"
            android:layout_marginTop="14dp"
            android:hint="Новый пароль"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etNewPasswordConfirmation"
            style="@style/LambaFormInput"
            android:layout_marginTop="14dp"
            android:hint="Повторите новый пароль"
            android:inputType="textPassword" />

        <TextView
            android:id="@+id/tvPasswordError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#960018"
            android:textSize="16sp"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_lamba_send_button"
            android:text="Изменить пароль"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProfileLogout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_lamba_bot_bubble"
            android:text="Выйти"
            android:textAllCaps="false"
            android:textColor="#960018"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/profileProgressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:indeterminateTint="#960018"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
